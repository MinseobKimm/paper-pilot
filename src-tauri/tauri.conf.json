{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Paper Pilot",
  "version": "0.1.0",
  "identifier": "local.paper-pilot.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paper Pilot",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
